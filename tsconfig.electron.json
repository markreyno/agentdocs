{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node", "electron"],
    "skipLibCheck": true,

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "noEmit": false,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["electron"]
}
